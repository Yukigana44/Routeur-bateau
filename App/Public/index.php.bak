<?php

require_once __DIR__ . '/../../vendor/autoload.php';

use App\Router;

$router = new Router();

$router->get('/', function () {
    include __DIR__ . '/home.php';
});

$router->get('/login', function () {
    include __DIR__ . '/login.php';
});
$router->post('/login', function () {
    include __DIR__ . '/login.php';
});

$router->get('/register', function () {
    include __DIR__ . '/register.php';
});
$router->post('/register', function () {
    include __DIR__ . '/register.php';
});

$router->get('/dashboard', function () {
    include __DIR__ . '/dashboard.php';
});
$router->post('/dashboard', function () {
    include __DIR__ . '/dashboard.php';
});

$router->get('/logout', function () {
    include __DIR__ . '/logout.php';
});

$router->get('/trajets/nouveau', function () {
    include __DIR__ . '/nouveau-trajet.php';
});
$router->post('/trajets/nouveau', function () {
    include __DIR__ . '/nouveau-trajet.php';
});

$router->get('/trajets/{id}/modifier', function ($params) {
    $_GET['id'] = $params['id'];
    include __DIR__ . '/modifier-trajet.php';
});
$router->post('/trajets/{id}/modifier', function ($params) {
    $_GET['id'] = $params['id'];
    include __DIR__ . '/modifier-trajet.php';
});

$router->dispatch($_SERVER['REQUEST_METHOD'], $_SERVER['REQUEST_URI']);
